---
import FilterSection from "../components/FilterSection.astro";
import HeroSection from "../components/HeroSection.astro";
import ResourcesGrid from "../components/ResourcesGrid.astro";
import Layout from "../layouts/Layout.astro";
import { getTodosLosRecursos, categoriaLabels } from "../lib/resources";

const allResources = await getTodosLosRecursos();
const categories = Object.keys(categoriaLabels);
---

<Layout
  title="DevResources - Directorio de recursos para desarrolladores web"
  description="Descubre los mejores frameworks, librerías UI, herramientas y recursos para desarrolladores web. Todo en un solo lugar, organizado y fácil de encontrar."
>
  <!-- Hero Section -->
  <HeroSection />

  <!-- Filters Section -->
  <FilterSection
    categories={categories}
    categoriaLabels={categoriaLabels}
    allResources={allResources}
  />

  <!-- Resources Grid -->
  <ResourcesGrid
    categoriaLabels={categoriaLabels}
    allResources={allResources}
  />
</Layout>


