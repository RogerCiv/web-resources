---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import GlobalScripts from "../components/GlobalScripts.astro";
import Analytics from '@vercel/analytics/astro'
import SEO from "../components/SEO.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const { 
  title, 
  description = "Web Recursos: El directorio más completo para desarrolladores web. Encuentra frameworks, librerías UI, herramientas de diseño, APIs y mucho más para potenciar tu flujo de trabajo.",
  image = "/og-image.png",
  url,
  type = "website"
} = Astro.props;

const baseURL = Astro.site || new URL('https://web-recursos.vercel.app');
const canonicalURL = new URL(url || Astro.url.pathname, baseURL);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <SEO 
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      type={type}
    />
    
    <meta name="google-site-verification" content="gwlgeNsfdspJp4JwbujAZa0njIROX9-9cubbziLc-Ow" />
    <meta name="keywords" content="web recursos, recursos desarrolladores, herramientas web, frameworks, librerías UI, diseño web, APIs gratuitas, aprendizaje programación" />
    
    <!-- Preload critical fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <script is:inline>
    (function() {
      const savedTheme = localStorage.getItem('darkMode');
      if (savedTheme === 'true') {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  </head>
  <!-- Updated body background to match design system -->
  <body class="bg-background font-sans antialiased">
    <Analytics />
    <!-- Navigation -->
    <Navbar />

    <!-- Main Content -->
    <main class="min-h-screen">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <GlobalScripts />

    <style>
      /* Updated font family reference */
      .font-inter {
        font-family: 'Inter', sans-serif;
      }
      
      /* Mejoras para el dropdown */
      .group:hover .group-hover\:opacity-100 {
        opacity: 1;
      }
      .group:hover .group-hover\:visible {
        visibility: visible;
      }
    </style>
  </body>
</html>
