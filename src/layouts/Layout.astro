---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro'
import SEO from "../components/SEO.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const { 
  title, 
  description = "Web Recursos: El directorio más completo para desarrolladores web. Encuentra frameworks, librerías UI, herramientas de diseño, APIs y mucho más para potenciar tu flujo de trabajo.",
  image = "/og-image.png",
  url,
  type = "website"
} = Astro.props;

const baseURL = Astro.site || new URL('https://web-recursos.vercel.app');
const canonicalURL = new URL(url || Astro.url.pathname, baseURL);
---

<!doctype html>
<html lang="es" class="scroll-smooth" style="color-scheme: dark">
  <head>
    <SEO 
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      type={type}
    />
    
    <meta name="google-site-verification" content="gwlgeNsfdspJp4JwbujAZa0njIROX9-9cubbziLc-Ow" />
    <meta name="keywords" content="web recursos, recursos desarrolladores, herramientas web, frameworks, librerías UI, diseño web, APIs gratuitas, aprendizaje programación" />
    <meta name="theme-color" content="#0b0d14" />
    
    <!-- Preload critical fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
  </head>
  <!-- Updated body background to match design system -->
  <body class="bg-background font-sans antialiased">
    <Analytics />
    
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-accent focus:text-white focus:outline-none">
      Saltar al contenido principal
    </a>

    <!-- Navigation -->
    <Navbar />

    <!-- Main Content -->
    <main id="main-content" class="min-h-screen">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <style>
      /* Updated font family reference */
      .font-inter {
        font-family: 'Inter', sans-serif;
      }
      
      /* Mejoras para el dropdown */
      .group:hover .group-hover\:opacity-100 {
        opacity: 1;
      }
      .group:hover .group-hover\:visible {
        visibility: visible;
      }
    </style>
  </body>
</html>
