---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import GlobalScripts from "../components/GlobalScripts.astro";
import Analytics from '@vercel/analytics/astro'

export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const { 
  title, 
  description = "Directorio completo de recursos para desarrolladores web: frameworks, librerías UI, herramientas y más.",
  image = "/og-image.png",
  url,
  type = "website"
} = Astro.props;

// Manejo seguro de URL canónica
const baseURL = Astro.site || new URL('http://localhost:4321');
const canonicalURL = new URL(url || Astro.url.pathname, baseURL);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, baseURL)} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, baseURL)} />
    
    <!-- Preload critical fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "DevResources",
        "description": "Directorio de recursos para desarrolladores web",
        "url": canonicalURL.toString(),
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `${canonicalURL.origin}/search?q={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      }
    </script>
      <script is:inline>
    (function() {
      const savedTheme = localStorage.getItem('darkMode');
      if (savedTheme === 'true') {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  </head>
  <!-- Updated body background to match design system -->
  <body class="bg-background font-sans antialiased">
    <Analytics />
    <!-- Navigation -->
    <Navbar />

    <!-- Main Content -->
    <main class="min-h-screen">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <GlobalScripts />

    <style>
      /* Updated font family reference */
      .font-inter {
        font-family: 'Inter', sans-serif;
      }
      
      /* Mejoras para el dropdown */
      .group:hover .group-hover\:opacity-100 {
        opacity: 1;
      }
      .group:hover .group-hover\:visible {
        visibility: visible;
      }
    </style>
  </body>
</html>
