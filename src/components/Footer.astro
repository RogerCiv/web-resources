---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-auto">
  <div
    class="mx-auto max-w-7xl px-6 py-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-between"
  >
    <p class="text-sm text-text-muted">
      &copy; {year} Recursos<span class="text-accent">Web</span>. Hecho con Astro ❤️.
    </p>
    <p class="text-sm text-text-dimmed">
      Directorio curado de recursos para desarrolladores
    </p>
  </div>
</footer>
