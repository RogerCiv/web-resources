---
import type { RecursoCompleto } from "../lib/resources";

export interface Props {
  categories: string[];
  categoriaLabels: Record<string, string>;
  allResources: RecursoCompleto[];
}

const { categories, categoriaLabels, allResources } = Astro.props;
---

<!-- Updated filter section with emerald theme and modern styling -->
<section
  class="bg-background/80 backdrop-blur-sm border-b border-border sticky top-16 z-40"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col sm:flex-row gap-4 items-center">
      <label class="text-sm font-semibold text-foreground whitespace-nowrap">
        Filtrar por categoría:
      </label>
      <select
        id="category-filter"
        class="px-4 py-2.5 border border-border rounded-lg focus:ring-2 focus:ring-ring focus:border-primary transition-colors duration-200 bg-background shadow-sm hover:border-muted-foreground text-foreground"
      >
        <option value="">Todas las categorías</option>
        {
          categories.map((categoria) => (
            <option value={categoria}>{categoriaLabels[categoria]}</option>
          ))
        }
      </select>
      <!-- Search input -->
      <div class="relative w-full max-w-md mx-auto">
        <input
          type="text"
          id="search-input"
          placeholder="Buscar recursos..."
          class="w-full px-4 py-2.5 pl-12 border border-border rounded-lg
                text-white placeholder-gray-300
               focus:ring-2 focus:ring-emerald-500 focus:border-transparent
               transition-colors duration-200"
        />
        <svg
          class="absolute left-4 top-3.5 h-5 w-5 text-gray-500"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <div
        class="ml-auto text-sm text-muted-foreground bg-muted px-3 py-2 rounded-lg border border-border"
      >
        <span id="results-count" class="font-semibold text-primary"
          >{allResources.length}</span
        >
        <span class="text-foreground">recursos encontrados</span>
      </div>
    </div>
  </div>
</section>
