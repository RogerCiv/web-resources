---
import { categoriaLabels, categoriaIcons, type CollectionName, } from "../lib/resources";
import type { RecursoCompleto } from "../lib/resources";

interface Props {
  categories: CollectionName[];
  allResources: RecursoCompleto[];
}

const { categories, allResources } = Astro.props;

// Count resources per category
const categoryCounts: Record<CollectionName, number> = {} as Record<
  CollectionName,
  number
>;
for (const cat of categories) {
  categoryCounts[cat] = allResources.filter(
    (r) => r.categoria === cat
  ).length;
}

const activeCategories: CollectionName[] = categories.filter(
  (c) => categoryCounts[c] > 0
);
---

<section class="mx-auto max-w-7xl px-6 pb-4">
  <div class="flex items-center gap-3 mb-4">
    <h2 class="text-sm font-medium text-text-muted uppercase tracking-wider">
      Categorías
    </h2>
    <div class="h-px flex-1 bg-border"></div>
    <div class="flex items-center gap-3 text-sm text-text-muted">
      <span id="results-count" class="font-semibold text-accent tabular-nums">{allResources.length}</span>
      <span>recursos</span>
    </div>
    <div class="flex items-center gap-2 text-sm text-text-muted">
      <label for="sort-select" class="hidden sm:inline">Orden</label>
      <select
        id="sort-select"
        class="rounded-lg border border-border bg-bg-card px-3 py-2 text-sm text-text-muted transition-all focus:border-accent focus:outline-none cursor-pointer"
      >
        <option value="alpha" selected>Alfabético</option>
        <option value="newest">Más nuevos</option>
      </select>
    </div>
  </div>

  <div id="category-filters" class="flex flex-wrap gap-2" role="tablist">
    <button
      data-category="all"
      role="tab"
      aria-selected="true"
      class="category-btn active inline-flex items-center gap-2 rounded-lg border px-3 py-2 text-sm font-medium transition-all cursor-pointer border-accent bg-accent-dimmed text-accent"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7"></rect>
        <rect x="14" y="3" width="7" height="7"></rect>
        <rect x="14" y="14" width="7" height="7"></rect>
        <rect x="3" y="14" width="7" height="7"></rect>
      </svg>
      Todos
      <span class="rounded-md bg-accent/20 px-1.5 py-0.5 text-xs font-semibold tabular-nums">{allResources.length}</span>
    </button>

    {
      activeCategories.map((cat) => (
        <button
          data-category={cat}
          role="tab"
          aria-selected="false"
          class="category-btn inline-flex items-center gap-2 rounded-lg border px-3 py-2 text-sm font-medium transition-all cursor-pointer border-border text-text-muted hover:border-border-hover hover:text-text hover:bg-bg-surface"
        >
          <span set:html={categoriaIcons[cat] || ""} />
          {categoriaLabels[cat] || cat}
          <span class="rounded-md bg-bg-surface px-1.5 py-0.5 text-xs tabular-nums">
            {categoryCounts[cat]}
          </span>
        </button>
      ))
    }
  </div>
</section>
