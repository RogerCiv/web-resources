---
import type { RecursoCompleto } from '../lib/resources';



export interface Props {
  categoriaLabels: Record<string, string>;
  allResources: RecursoCompleto[];
}

const { categoriaLabels, allResources } = Astro.props;
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div
    id="resource-list"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
  >
    {
      allResources.map((resource) => (
    <article
      class="resource-card bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-gray-700 
            hover:border-emerald-300 dark:hover:border-emerald-600 hover:shadow-lg hover:scale-105
            transform transition-transform duration-300 ease-out
            p-6 flex flex-col h-full group"
      data-category={resource.categoria}
      data-tags={resource.data.tags.join(",")}
      data-name={resource.data.name.toLowerCase()}
      data-description={resource.data.description.toLowerCase()}
    >
  <!-- Header -->
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center space-x-3">
      {resource.data.image ? (
        <img
          src={resource.data.image}
          alt={resource.data.name}
          class="w-10 h-10 rounded-lg object-cover"
          loading="lazy"
        />
      ) : (
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-500 to-emerald-600 
                    flex items-center justify-center text-white font-bold text-sm">
          {(() => {
            const words = resource.data.name.split(" ");
            const firstWord = words[0] || "";
            const secondWord = words[1] || "";
            return secondWord 
              ? (firstWord.slice(0, 2) + secondWord.charAt(0)).toUpperCase()
              : firstWord.slice(0, 2).toUpperCase();
          })()}
        </div>
      )}
      <div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">
          {resource.data.name}
        </h3>
        <span class="inline-block px-2 py-1 text-xs font-medium bg-emerald-100 dark:bg-emerald-900 text-emerald-800 dark:text-emerald-200 rounded-full">
          {categoriaLabels[resource.categoria]}
        </span>
      </div>
    </div>
    
    <!-- Price badge with better dark mode -->
    <span class={`text-xs font-semibold px-2 py-1 rounded transition-colors ${
      resource.data.price === "free" 
        ? "text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900" 
        : resource.data.price === "freemium" 
          ? "text-yellow-700 dark:text-yellow-300 bg-yellow-100 dark:bg-yellow-900" 
          : "text-red-700 dark:text-red-300 bg-red-100 dark:bg-red-900"
    }`}>
      {resource.data.price === "free" ? "Gratis" : resource.data.price === "freemium" ? "Freemium" : "Pago"}
    </span>
  </div>

  <!-- Content -->
  <div class="flex-grow">
    <p class="text-gray-600 dark:text-gray-300 mb-4 text-sm leading-relaxed">
      {resource.data.description}
    </p>

    <div class="flex flex-wrap gap-1 mb-4">
      {resource.data.tags.slice(0, 3).map((tag) => (
        <span class="inline-block px-2 py-1 text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded transition-colors">
          {tag}
        </span>
      ))}
      {resource.data.tags.length > 3 && (
        <span class="inline-block px-2 py-1 text-xs text-gray-500 dark:text-gray-400">
          +{resource.data.tags.length - 3} más
        </span>
      )}
    </div>
  </div>

  <!-- Buttons -->
  <div class="flex space-x-2 mt-auto">
    {resource.data.documentation && (
      <a
        href={resource.data.documentation}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white text-center py-2 px-3 rounded-md text-sm font-medium transition-colors duration-200"
      >
        Ver Docs
      </a>
    )}
    {resource.data.github && (
      <a
        href={resource.data.github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 bg-gray-800 hover:bg-gray-900 dark:bg-gray-700 dark:hover:bg-gray-600 text-white text-center py-2 px-3 rounded-md text-sm font-medium transition-colors duration-200"
      >
        GitHub
      </a>
    )}
  </div>
</article>
      ))
    }
  </div>

  <div id="no-results" class="text-center py-16 hidden">
    <div class="text-muted-foreground mb-6">
      <svg
        class="mx-auto h-16 w-16 opacity-50"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6m2 5.291A7.962 7.962 0 0112 15c-2.34 0-4.47-.881-6.071-2.33"
        ></path>
      </svg>
    </div>
    <h3 class="text-xl font-semibold text-card-foreground mb-2">
      No se encontraron recursos
    </h3>
    <p class="text-muted-foreground max-w-md mx-auto text-pretty">
      No se encontraron recursos que coincidan con tu búsqueda. Intenta con otros términos o filtros.
    </p>
  </div>
</section>
