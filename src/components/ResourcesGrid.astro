---
import type { RecursoCompleto } from '../lib/resources';

export interface Props {
  categoriaLabels: Record<string, string>;
  allResources: RecursoCompleto[];
}

const { categoriaLabels, allResources } = Astro.props;
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div
    id="resource-list"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
  >
    {
      allResources.map((resource) => (
        <article
          class="resource-card group bg-card rounded-xl border border-border hover:border-primary/30 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden h-full flex flex-col"
          data-category={resource.categoria}
          data-tags={resource.data.tags.join(",")}
          data-name={resource.data.name.toLowerCase()}
          data-description={resource.data.description.toLowerCase()}
        >
          <div class="relative p-6 pb-4">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center space-x-4">
                {resource.data.image ? (
                  <div class="relative">
                    <img
                      src={resource.data.image || "/placeholder.svg"}
                      alt={resource.data.name}
                      class="w-12 h-12 rounded-xl object-cover ring-2 ring-border group-hover:ring-primary/30 transition-all duration-300"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div
                    class={`w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-sm shadow-lg group-hover:scale-105 transition-transform duration-300 ${
                      resource.categoria === "frameworks"
                        ? "bg-gradient-to-br from-primary to-primary/80"
                        : resource.categoria === "ui-libraries"
                          ? "bg-gradient-to-br from-secondary to-secondary/80"
                          : resource.categoria === "tools"
                            ? "bg-gradient-to-br from-accent to-accent/80"
                            : "bg-gradient-to-br from-muted-foreground to-muted-foreground/80"
                    }`}
                  >
                    {(() => {
                      const words = resource.data.name.split(" ");
                      const firstWord = words[0] || "";
                      const secondWord = words[1] || "";

                      if (secondWord) {
                        return (
                          firstWord.slice(0, 2) + secondWord.charAt(0)
                        ).toUpperCase();
                      } else {
                        return firstWord.slice(0, 2).toUpperCase();
                      }
                    })()}
                  </div>
                )}
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-card-foreground mb-2 group-hover:text-primary transition-colors duration-300 text-balance">
                    {resource.data.name}
                  </h3>
                  <span class="inline-flex items-center px-3 py-1 text-xs font-semibold bg-primary/10 text-primary rounded-full border border-primary/20 group-hover:bg-primary/20 transition-colors duration-300">
                    {categoriaLabels[resource.categoria]}
                  </span>
                </div>
              </div>
              
              <div class="flex-shrink-0">
                <span
                  class={`inline-flex items-center px-3 py-1.5 text-xs font-bold rounded-full shadow-sm transition-all duration-300 group-hover:scale-105 ${
                    resource.data.price === "free" 
                      ? "text-emerald-700 bg-emerald-50 border border-emerald-200" 
                      : resource.data.price === "freemium" 
                        ? "text-amber-700 bg-amber-50 border border-amber-200" 
                        : "text-rose-700 bg-rose-50 border border-rose-200"
                  }`}
                >
                  {resource.data.price === "free"
                    ? "Gratis"
                    : resource.data.price === "freemium"
                      ? "Freemium"
                      : "Pago"}
                </span>
              </div>
            </div>
          </div>

          <div class="px-6 pb-4 flex-1 flex flex-col">
            <div class="h-20 mb-4">
              <p class="text-foreground text-sm leading-relaxed text-pretty line-clamp-4">
                {resource.data.description}
              </p>
            </div>
            
            <div class="flex flex-wrap gap-2 min-h-[2.5rem] mt-auto">
              {resource.data.tags.map((tag) => (
                <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium bg-muted text-muted-foreground rounded-md border border-border hover:bg-accent/10 hover:text-accent hover:border-accent/30 transition-all duration-200">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <div class="p-6 pt-0 mt-auto">
            <div class="flex gap-3">
              {resource.data.documentation && (
                <a
                  href={resource.data.documentation}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 bg-primary text-primary-foreground text-center py-2.5 px-4 rounded-lg text-sm font-semibold hover:bg-primary/90 hover:shadow-lg hover:scale-[1.02] transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
                >
                  Ver Docs
                </a>
              )}
              {resource.data.github && (
                <a
                  href={resource.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 bg-card-foreground text-background text-center py-2.5 px-4 rounded-lg text-sm font-semibold hover:bg-card-foreground/90 hover:shadow-lg hover:scale-[1.02] transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
                >
                  GitHub
                </a>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </div>

  <div id="no-results" class="text-center py-16 hidden">
    <div class="text-muted-foreground mb-6">
      <svg
        class="mx-auto h-16 w-16 opacity-50"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6m2 5.291A7.962 7.962 0 0112 15c-2.34 0-4.47-.881-6.071-2.33"
        ></path>
      </svg>
    </div>
    <h3 class="text-xl font-semibold text-card-foreground mb-2">
      No se encontraron recursos
    </h3>
    <p class="text-muted-foreground max-w-md mx-auto text-pretty">
      No se encontraron recursos que coincidan con tu búsqueda. Intenta con otros términos o filtros.
    </p>
  </div>
</section>
