---
interface Props {
  totalResources: number;
}
const { totalResources } = Astro.props;
---

<section class="relative overflow-hidden">
  <!-- Subtle glow -->
  <div
    class="pointer-events-none absolute left-1/2 top-0 -translate-x-1/2 h-[300px] w-[600px] rounded-full bg-accent/5 blur-[120px]"
  >
  </div>

  <div
    class="relative mx-auto max-w-7xl px-6 pt-20 pb-12 text-center"
  >
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent-border bg-accent-dimmed px-4 py-1.5"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
      <span class="text-sm font-medium text-accent"
        >{totalResources} recursos disponibles</span
      >
    </div>

    <h1
      class="mx-auto max-w-3xl text-4xl font-bold leading-tight tracking-tight text-text sm:text-5xl lg:text-6xl text-balance"
    >
      Todo lo que necesitas para
      <span
        class="bg-gradient-to-r from-accent to-accent-hover bg-clip-text text-transparent"
        >desarrollar la web</span
      >
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted text-pretty"
    >
      Directorio curado de frameworks, herramientas, APIs y recursos esenciales
      para potenciar tu flujo de trabajo como desarrollador.
    </p>

    <!-- Search -->
    <div class="mx-auto mt-10 max-w-xl">
      <div class="relative group">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="absolute left-4 top-1/2 -translate-y-1/2 text-text-dimmed transition-colors group-focus-within:text-accent"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          type="search"
          id="search-input"
          placeholder="Buscar recursos, frameworks, herramientas..."
          autocomplete="off"
          class="w-full rounded-xl border border-border bg-bg-card py-3.5 pl-12 pr-4 text-text placeholder:text-text-dimmed transition-all focus:border-accent focus:bg-bg-card-hover focus:outline-none focus:ring-1 focus:ring-accent/30"
        />
        <kbd
          class="absolute right-4 top-1/2 -translate-y-1/2 hidden rounded-md border border-border bg-bg-surface px-2 py-0.5 text-xs text-text-dimmed sm:inline-block"
          >/</kbd
        >
      </div>
    </div>
  </div>
</section>

<script>
  // Focus search on "/" key
  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && document.activeElement?.tagName !== "INPUT") {
      e.preventDefault();
      document.getElementById("search-input")?.focus();
    }
  });
</script>
